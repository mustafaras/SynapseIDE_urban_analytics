{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(npx eslint:*)",
      "Bash(npx playwright:*)",
      "Bash(npx vite:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git stash list:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "PowerShell(Get-ChildItem -Path *)",
      "PowerShell(Test-Path *)",
      "PowerShell(Get-Content *)",
      "PowerShell(Get-Process *)",
      "PowerShell(Get-NetTCPConnection *)",
      "PowerShell(.\\\\scripts\\\\get-next-map-explorer-prompt.ps1 -Json)",
      "PowerShell(pwsh -NoProfile -ExecutionPolicy Bypass -File .\\\\scripts\\\\get-next-map-explorer-prompt.ps1 -Json)",
      "Bash(sed -i '117,471d' src/centerpanel/components/map/MapLayerManager.tsx)",
      "Bash(sed -n '113,125p' src/centerpanel/components/map/MapLayerManager.tsx)",
      "Bash(npx vite-node *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)"
    ],
    "deny": [
      "Read(side_UA.mp4)",
      "Read(eslint-errors.json)",
      "Read(package-lock.json)",
      "Read(.venv/**)",
      "Read(node_modules/**)",
      "Read(dist/**)",
      "Read(coverage/**)",
      "Read(test-results/**)"
    ]
  },
  "effortLevel": "medium"
}
