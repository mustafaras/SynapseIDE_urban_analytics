# Urban Analytics Workbench — Environment Variables
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# ──────────────────────────────────────────────
# Map Providers (at least one recommended)
# ──────────────────────────────────────────────
VITE_MAPBOX_ACCESS_TOKEN=
VITE_GOOGLE_MAPS_API_KEY=

# ──────────────────────────────────────────────
# AI Providers (optional — enable any combination)
# ──────────────────────────────────────────────
VITE_OPENAI_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_GEMINI_API_KEY=
VITE_OLLAMA_BASE_URL=http://localhost:11434

# ──────────────────────────────────────────────
# Application Profile
# ──────────────────────────────────────────────
VITE_PROFILE=dev

# ──────────────────────────────────────────────
# Observability (optional)
# ──────────────────────────────────────────────
VITE_OTLP_HTTP=http://localhost:4318/v1/traces

# ──────────────────────────────────────────────
# Feature Flags (optional)
# ──────────────────────────────────────────────
VITE_AI_TRACE=false
VITE_SIMPLE_STREAM=true
VITE_SYN_CORE_AI=true

# ──────────────────────────────────────────────
# GeoAI Object Detection (optional)
# ──────────────────────────────────────────────
# Browser-loadable ONNX model URL for the real detector path.
# The checked-in smoke model validates the browser runtime path only; it is not a production detector.
VITE_GEOAI_OBJECT_DETECTION_MODEL_URL=/models/yolo-nano-urban-local-smoke.onnx
# Runtime backend for onnxruntime-web. Prefer wasm unless you have a known-good WebGPU path.
VITE_GEOAI_OBJECT_DETECTION_BACKEND=wasm

# ──────────────────────────────────────────────
# Theme
# ──────────────────────────────────────────────
VITE_THEME_MODE=dark
