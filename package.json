{
  "name": "urban-analytics-workbench",
  "private": true,
  "version": "1.0.0",
  "description": "Browser-based spatial intelligence platform for urban scientists, planners, and GIS analysts",
  "type": "module",
  "scripts": {
    "start": "node --max-old-space-size=12288 node_modules/vite/bin/vite.js",
    "predev": "node scripts/kill-port.cjs 3000 9231",
    "dev": "concurrently -n vite,terminal -c cyan,yellow \"node --max-old-space-size=12288 node_modules/vite/bin/vite.js\" \"node server/terminal-server.cjs\"",
    "dev:vite": "node --max-old-space-size=12288 node_modules/vite/bin/vite.js",
    "dev:trace": "node --max-old-space-size=12288 node_modules/vite/bin/vite.js",
    "dev:safe": "node --max-old-space-size=12288 node_modules/vite/bin/vite.js --host 0.0.0.0 --port 3000",
    "dev:cmd": "node --max-old-space-size=12288 node_modules/vite/bin/vite.js",
    "build": "node --max-old-space-size=12288 node_modules/vite/bin/vite.js build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:errors": "eslint . --ext ts,tsx --quiet",
    "lint:urban-tests": "eslint \"src/features/urbanAnalytics/**/*.{ts,tsx}\" \"src/**/__tests__/**/*.{ts,tsx}\"",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "lint:ci": "eslint . --ext ts,tsx --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "clean": "rimraf dist .turbo .cache coverage",
    "guardrails:ci": "node -e \"import('./dist/services/ai/guardrails/redact.js').then(m=>{const t=process.env.GUARD_SAMPLE||'';const r=m.redact(t);if(r.warnings.length){console.log(r.warnings.join('\\n'));process.exit(1)}else{console.log('OK')}})\"",
    "lint:no-tailwind-centerpanel": "powershell -ExecutionPolicy Bypass -File scripts/check-no-tailwind-centerpanel.ps1",
    "deadcode": "ts-prune -p tsconfig.json",
    "deadcode:json": "ts-prune -p tsconfig.json --json > .deadcode.json",
    "deadcode:knip": "knip --reporter json > .knip-report.json",
    "wasm:build:spatial-index": "node scripts/build-spatial-index-wasm.mjs",
    "test": "vitest run",
    "test:analytics": "vitest run src/engine src/features/urbanAnalytics src/services/data src/workers/pool src/centerpanel/Tools/__tests__/CoverageDiagnosticsPanel.test.tsx",
    "test:coverage": "vitest run --coverage src/engine src/features/urbanAnalytics src/services/data src/workers/pool src/centerpanel/Tools/__tests__/CoverageDiagnosticsPanel.test.tsx",
    "test:coverage:publish": "vitest run --coverage src/engine src/features/urbanAnalytics src/services/data src/workers/pool src/centerpanel/Tools/__tests__/CoverageDiagnosticsPanel.test.tsx && node scripts/export-coverage-summary.mjs",
    "test:watch": "vitest watch",
    "test:e2e": "playwright test",
    "test:e2e:a11y": "playwright test e2e/accessibility-audit.spec.ts",
    "test:e2e:smoke": "playwright test --grep \"@smoke\"",
    "test:e2e:rest": "playwright test --grep-invert \"@smoke\"",
    "test:e2e:functional": "playwright test --grep-invert \"@smoke|@a11y\"",
    "test:e2e:ci": "npm run test:e2e:smoke && npm run test:e2e:a11y && npm run test:e2e:functional",
    "test:e2e:headed": "playwright test --headed",
    "perf:budgets": "node scripts/check-bundle-budgets.mjs",
    "perf:budgets:json": "node scripts/check-bundle-budgets.mjs --json",
    "validate:rc": "npm run typecheck && npm run lint:errors && npm run test && npm run build && npm run perf:budgets && npm run test:e2e:ci",
    "terminal-server": "node server/terminal-server.cjs",
    "dev:full": "concurrently -n vite,terminal -c cyan,yellow \"node --max-old-space-size=12288 node_modules/vite/bin/vite.js\" \"node server/terminal-server.cjs\""
  },
