{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synapseide.local/schemas/map-explorer-premium-redesign-implementation-prompts.schema.json",
  "title": "Map Explorer Premium Redesign Implementation Prompts",
  "description": "Machine-readable contract for the Map Explorer Premium Redesign prompt sequence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packId",
    "title",
    "sourceMarkdown",
    "statusVocabulary",
    "prompts"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "packId": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "sourceMarkdown": {
      "type": "string",
      "minLength": 1
    },
    "statusVocabulary": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/promptStatus"
      }
    },
    "prompts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/prompt"
      }
    }
  },
  "$defs": {
    "promptStatus": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "implemented",
        "blocked",
        "verified",
        "deferred"
      ]
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commands"
      ],
      "properties": {
        "commands": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "number",
        "title",
        "status",
        "objective",
        "read",
        "tasks",
        "acceptance",
        "validation"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^prompt-[0-9]{2}$"
        },
        "number": {
          "type": "integer",
          "minimum": 0
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/promptStatus"
        },
        "objective": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "read": {
          "$ref": "#/$defs/stringList"
        },
        "tasks": {
          "$ref": "#/$defs/stringList"
        },
        "acceptance": {
          "$ref": "#/$defs/stringList"
        },
        "validation": {
          "$ref": "#/$defs/validation"
        },
        "uxIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^UX-[0-9]{2}$"
          }
        }
      }
    }
  }
}
